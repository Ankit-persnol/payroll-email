{
  "name": "payroll-email",
  "version": "0.1.0",
  "description": "HR Payroll Email Automation Desktop App",
  "main": "electron/main.js",
  "author": "HR Tools",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "build": "vite build",
    "package": "npm run build && electron-builder",
    "start": "electron .",
    "postinstall": "electron-rebuild -w better-sqlite3"
  },
  "dependencies": {
    "@sendgrid/mail": "^8.1.3",
    "better-sqlite3": "^11.3.0",
    "electron-store": "^8.2.0",
    "nodemailer": "^6.9.15",
    "papaparse": "^5.4.1",
    "pdfkit": "^0.15.0",
    "safe-stable-stringify": "^2.5.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^32.1.2",
    "electron-builder": "^25.0.5",
    "lucide-react": "^0.445.0",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "tailwindcss": "^3.4.13",
    "vite": "^5.4.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.hrtools.payrollemail",
    "productName": "Payroll Email",
    "files": [
      "electron/**/*",
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
